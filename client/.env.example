# client 환경변수 예시 — 이 파일을 복사해 `client/.env` 를 만들고 값을 채우세요.
#   cp .env.example .env   (.env 는 .gitignore 로 제외됨)
# ⚠️ VITE_ 접두사 변수는 빌드 결과물에 그대로 포함된다(프론트 공개). 비밀값을 넣지 말 것.

# Kakao 지도 JS 키 — L-05 지도 표시 (Web 플랫폼 도메인에 http://localhost:5173 등록 필요)
VITE_KAKAO_JS_KEY=

# (선택) 네이티브 앱 빌드 시 백엔드 절대주소. 미지정 시 '/api'(Vite 프록시) 사용
VITE_API_BASE=
