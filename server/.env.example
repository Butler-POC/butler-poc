# server 환경변수 예시 — 이 파일을 복사해 `server/.env` 를 만들고 값을 채우세요.
#   cp .env.example .env   (값은 절대 커밋하지 말 것; .env 는 .gitignore 로 제외됨)

# MySQL(AWS RDS) 연결 문자열 — Prisma 가 이 값만 사용
#   형식: mysql://<user>:<password>@<host>:3306/<database>
DATABASE_URL=

# (참고용) DATABASE_URL 조립용 개별 값 — Prisma 가 직접 읽지는 않음
DB_HOST=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Claude(Anthropic) API 키 — C-02 챗봇 / L-06 / T-02 / C-01 비전 OCR
API_KEY=

# Kakao 로컬(키워드) 검색 REST 키 — L-05 수선 업체 조회 (서버 전용)
KAKAO_REST_KEY=

# JWT 서명 시크릿 — 로그인 토큰 발급/검증 (임의의 긴 무작위 문자열)
JWT_SECRET=

# 서버 포트 (미지정 시 3000)
PORT=
